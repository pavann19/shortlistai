{
  "manifest_version": 3,
  "name": "ATS Copilot Scraper",
  "version": "1.0",
  "description": "Scrape job postings from LinkedIn & Indeed directly into your local Job Tracker.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/*", "*://*.indeed.com/*", "*://*.glassdoor.com/*"],
      "js": ["content.js"]
    }
  ]
}
